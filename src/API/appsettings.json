{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OAuth": {
    "SoundCloud": {
      "ClientId": "your_soundcloud_client_id",
      "ClientSecret": "your_soundcloud_client_secret",
      "RedirectUri": "https://localhost:7270/StreamingAuth/2/callback",
      "Scopes": "non-expiring",
      "Endpoints": {
        "AuthorizationEndpoint": "https://secure.soundcloud.com/authorize",
        "TokenEndpoint": "https://secure.soundcloud.com/oauth/token",
        "UserProfileEndpoint": "https://api.soundcloud.com/me"
      }
    },
    "Spotify": {
      "ClientId": "your_spotify_client_id",
      "ClientSecret": "your_spotify_client_secret",
      "RedirectUri": "https://127.0.0.1:7270/StreamingAuth/0/callback",
      "Endpoints": {
        "OAuthServerEndpoint": "https://accounts.spotify.com/authorize",
        "TokenEndpoint": "https://accounts.spotify.com/api/token",
        "UserProfileEndpoint": "https://api.spotify.com/v1/me"
      }
    },
    "Google": {
      "ClientId": "your_google_client_id",
      "ClientSecret": "your_google_client_secret",
      "CallbackUri": "https://localhost:7270/Auth/google/callback",
      "YoutubeMusicCallbackUri": "https://127.0.0.1:7270/StreamingAuth/1/callback",
      "Scopes": {
        "UserInfoScope": "openid profile email",
        "YouTubeScope": "https://www.googleapis.com/auth/youtube https://www.googleapis.com/auth/youtube.readonly"
      },
      "Endpoints": {
        "UserInfoEndpoint": "https://www.googleapis.com/oauth2/v2/userinfo",
        "OAuthServerEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
        "TokenEndpoint": "https://oauth2.googleapis.com/token"
      }
    }
  },
  "Encryption": {
    "KeyBase64": ""
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowAnyHeader": true,
    "AllowAnyMethod": true,
    "AllowCredentials": true
  },
  "Frontend": {
    "BaseUri": "http://localhost:5173"
  },
  "ConnectionStrings": {
    "WaveBridge": "Host=localhost;Port=5432;Database=waveBridge.main;Username=;Password="
  },
  "JwtOptions": {
    "Key": "",
    "Issuer": "WaveBridgeAPI",
    "Audience": "WaveBridgeClient",
    "ExpiresHours": 2,
    "RefreshTokenLifetimeDays": 7
  },
  "AdminUser": {
    "UserName": "",
    "Email": "",
    "Password": ""
  },
  "AuthorizationOptions": {
    "RolePermissions": [
      {
        "Name": "SuperAdmin",
        "Permissions": [
          "Transfers.Create",
          "Transfers.Read",
          "Users.Read",
          "Users.Update",
          "Users.Delete",
          "Roles.Manage"
        ]
      },
      {
        "Name": "Admin",
        "Permissions": [
          "Transfers.Read",
          "Users.Read",
          "Users.Update"
        ]
      },
      {
        "Name": "User",
        "Permissions": [
          "Transfers.Create",
          "Transfers.Read",
          "Users.Read",
          "Users.Update"
        ]
      },
      {
        "Name": "Visitor",
        "Permissions": [
          "Transfers.Read"
        ]
      }
    ]
  }
}
